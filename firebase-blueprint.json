{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "name": { "type": "string" },
        "school": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" },
        "ip": { "type": "string" },
        "country": { "type": "string" },
        "fingerprint": { "type": "string" }
      },
      "required": ["uid", "email", "registeredAt"]
    },
    "SecurityAlert": {
      "title": "SecurityAlert",
      "description": "A security alert for suspicious registration.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "ip": { "type": "string" },
        "country": { "type": "string" },
        "fingerprint": { "type": "string" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "ip", "fingerprint", "reason", "timestamp"]
    },
    "Candidate": {
      "title": "Candidate",
      "description": "A candidate in the election.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "logoUrl", "order"]
    },
    "Vote": {
      "title": "Vote",
      "description": "A cast vote.",
      "type": "object",
      "properties": {
        "voterId": { "type": "string" },
        "candidateId": { "type": "string" },
        "voterName": { "type": "string" },
        "voterSchool": { "type": "string" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["voterId", "candidateId", "voterName", "voterSchool", "reason", "timestamp"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global app settings.",
      "type": "object",
      "properties": {
        "votingEnabled": { "type": "boolean" },
        "registrationEnabled": { "type": "boolean" },
        "resultsEnabled": { "type": "boolean" }
      },
      "required": ["votingEnabled", "registrationEnabled", "resultsEnabled"]
    },
    "Stats": {
      "title": "Stats",
      "description": "Global app statistics.",
      "type": "object",
      "properties": {
        "visitCount": { "type": "number" }
      },
      "required": ["visitCount"]
    },
    "IPRegistry": {
      "title": "IPRegistry",
      "description": "Tracks UIDs associated with IP addresses.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    },
    "FingerprintRegistry": {
      "title": "FingerprintRegistry",
      "description": "Tracks UIDs associated with browser fingerprints.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores registered users."
    },
    "/candidates/{candidateId}": {
      "schema": { "$ref": "#/entities/Candidate" },
      "description": "Stores election candidates."
    },
    "/votes/{voteId}": {
      "schema": { "$ref": "#/entities/Vote" },
      "description": "Stores cast votes."
    },
    "/settings/global": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global voting settings."
    },
    "/stats/global": {
      "schema": { "$ref": "#/entities/Stats" },
      "description": "Global app statistics."
    },
    "/security_alerts/{alertId}": {
      "schema": { "$ref": "#/entities/SecurityAlert" },
      "description": "Stores security alerts for suspicious activity."
    },
    "/ip_registry/{ip}": {
      "schema": { "$ref": "#/entities/IPRegistry" },
      "description": "Registry for IP address tracking."
    },
    "/fingerprint_registry/{fingerprint}": {
      "schema": { "$ref": "#/entities/FingerprintRegistry" },
      "description": "Registry for browser fingerprint tracking."
    }
  }
}
