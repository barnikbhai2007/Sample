{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "registeredAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user registered."
        }
      },
      "required": ["uid", "email", "registeredAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores registered users."
    }
  }
}
